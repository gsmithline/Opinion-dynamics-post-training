# 0.5B full-FT beta-sweep with chat-templated prompts.
# Submit with:  condor_submit_bid 15 condor/llm_sweep_05b_fullft_chat.sub
# 0.5B full-FT fits comfortably on any modern GPU (well under 16 GB).

universe          = vanilla
executable        = /home/gsmithline/Opinion-dynamics-post-training/condor/run_one.sh
arguments         = $(tag) $(style) $(beta)

request_cpus      = 4
request_memory    = 32G
request_disk      = 20G
request_gpus      = 1
requirements      = (TARGET.CUDAGlobalMemoryMb >= 16000)

getenv            = False
environment       = "HF_HOME=/is/cluster/gsmithline/.cache/huggingface REPO=/home/gsmithline/Opinion-dynamics-post-training CONDA_SH=/home/gsmithline/miniconda3/etc/profile.d/conda.sh ENV_NAME=opdyn WANDB_KEY_FILE=/home/gsmithline/.wandb_key RETRAIN_T=30 SFT_EPOCHS=1 BASE_MODEL=Qwen/Qwen2.5-0.5B-Instruct USE_LORA=0 USE_CHAT_TEMPLATE=1 BATCH_SIZE=4 SAVE_ADAPTER=1"

output            = /home/gsmithline/Opinion-dynamics-post-training/condor/logs/$(tag).out
error             = /home/gsmithline/Opinion-dynamics-post-training/condor/logs/$(tag).err
log               = /home/gsmithline/Opinion-dynamics-post-training/condor/logs/$(tag).log

notification      = Complete
notify_user       = gabriel.smithline@tue.ellis.eu

max_retries       = 1
on_exit_hold      = (ExitCode =!= 0)

queue tag, style, beta from condor/configs_05b_fullft_chat.txt
