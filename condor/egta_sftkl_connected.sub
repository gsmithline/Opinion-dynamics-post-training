# HTCondor submit file for the SFT-KL sweep under a CONNECTED labeled split.
# The labeled subset is the connected subgraph V' produced by BFS in
# tools/make_connected_split.py. Path is pinned via LABELED_SPLIT env var.
#
# Mirrors egta_sftkl.sub + egta_sftkl_dense.sub exactly except for:
#   - tag suffix '_connected_egta'
#   - LABELED_SPLIT env var added
#   - configs file points to the connected variant
#
# Prereqs: before submitting, run
#   python tools/make_connected_split.py
# to produce pokec_dataset/parametric_params/connected_split.pkl.
#
# Submit:
#   condor_submit_bid 15 condor/egta_sftkl_connected.sub

universe          = vanilla
executable        = /home/gsmithline/Opinion-dynamics-post-training/condor/run_one.sh
arguments         = $(tag) $(style) $(beta)

request_cpus      = 2
request_memory    = 32G
request_disk      = 60G
request_gpus      = 1
requirements      = (TARGET.CUDAGlobalMemoryMb >= 16000) && (Machine =!= "g054.internal.cluster.is.localnet")

getenv            = False
environment       = "REPO=/home/gsmithline/Opinion-dynamics-post-training CONDA_SH=/home/gsmithline/miniconda3/etc/profile.d/conda.sh ENV_NAME=opdyn WANDB_KEY_FILE=/home/gsmithline/.wandb_key RETRAIN_T=30 SFT_EPOCHS=1 BASE_MODEL=Qwen/Qwen2.5-0.5B-Instruct USE_LORA=0 USE_CHAT_TEMPLATE=1 SAVE_ADAPTER=1 SAVE_ADAPTER_PER_ROUND=1 SAVE_ADAPTER_EVERY_N_ROUNDS=5 SAVE_PROMPTS=1 LABELED_SPLIT=/home/gsmithline/Opinion-dynamics-post-training/pokec_dataset/parametric_params/connected_split.pkl"

output            = /home/gsmithline/Opinion-dynamics-post-training/condor/logs/$(tag).out
error             = /home/gsmithline/Opinion-dynamics-post-training/condor/logs/$(tag).err
log               = /home/gsmithline/Opinion-dynamics-post-training/condor/logs/$(tag).log

notification      = Complete
notify_user       = gabriel.smithline@tue.ellis.eu

max_retries       = 1
on_exit_hold      = (ExitCode =!= 0)

queue tag, style, beta from condor/configs_egta_sftkl_connected.txt
