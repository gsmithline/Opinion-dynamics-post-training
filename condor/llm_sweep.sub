# HTCondor submit file for LLM + KL-beta sweep (5 configs).
# Submit with:  condor_submit_bid <BID> condor/llm_sweep.sub
# Each config runs run_one.sh with (tag, style, beta) pulled from configs.txt.

universe          = vanilla
executable        = /home/gsmithline/Opinion-dynamics-post-training/condor/run_one.sh
arguments         = $(tag) $(style) $(beta)

# ---- resources (adjust before submitting) ----
request_cpus      = 4
request_memory    = 32G
request_disk      = 20G
request_gpus      = 1
# Uncomment and tighten if you need a specific GPU class:
# requirements    = (TARGET.CUDAGlobalMemoryMb >= 16000)

# ---- env / io ----
getenv            = False
environment       = "REPO=/home/gsmithline/Opinion-dynamics-post-training CONDA_SH=/home/gsmithline/miniconda3/etc/profile.d/conda.sh ENV_NAME=opdyn WANDB_KEY_FILE=/home/gsmithline/.wandb_key RETRAIN_T=30 SFT_EPOCHS=1 BASE_MODEL=Qwen/Qwen2.5-0.5B-Instruct"

output            = /home/gsmithline/Opinion-dynamics-post-training/condor/logs/$(tag).out
error             = /home/gsmithline/Opinion-dynamics-post-training/condor/logs/$(tag).err
log               = /home/gsmithline/Opinion-dynamics-post-training/condor/logs/$(tag).log

# ---- email ----
notification      = Complete
notify_user       = gabriel.smithline@tue.ellis.eu

# Keep on-hold jobs around for debugging; retry transient faults.
max_retries       = 2
on_exit_hold      = (ExitCode =!= 0)

queue tag, style, beta from condor/configs.txt
