# HTCondor submit file for FJ SFT-KL EGTA sweep.
# Each job runs one FJ intervention (one beta) with per-round adapter saves +
# prompt persistence enabled so the EGTA cross-evaluation pipeline can consume
# the artifacts post-hoc.
#
# Submit:
#   condor_submit_bid 15 condor/egta_sftkl.sub
#
# Resource sizing assumes Qwen2.5-0.5B full-FT (USE_LORA=0). Trim
# request_memory/disk if you move to a smaller base model.
#
# Snapshot stride: SAVE_ADAPTER_EVERY_N_ROUNDS=5 with RETRAIN_T=30 produces
# checkpoints at rounds {0, 5, 10, 15, 20, 25, 30} = S=7 snapshots per run.

universe          = vanilla
executable        = /home/gsmithline/Opinion-dynamics-post-training/condor/run_one.sh
arguments         = $(tag) $(style) $(beta)

request_cpus      = 2
request_memory    = 32G
request_disk      = 60G
request_gpus      = 1
requirements      = (TARGET.CUDAGlobalMemoryMb >= 16000) && (Machine =!= "g054.internal.cluster.is.localnet")

getenv            = False
environment       = "REPO=/home/gsmithline/Opinion-dynamics-post-training CONDA_SH=/home/gsmithline/miniconda3/etc/profile.d/conda.sh ENV_NAME=opdyn WANDB_KEY_FILE=/home/gsmithline/.wandb_key RETRAIN_T=30 SFT_EPOCHS=1 BASE_MODEL=Qwen/Qwen2.5-0.5B-Instruct USE_LORA=0 SAVE_ADAPTER=1 SAVE_ADAPTER_PER_ROUND=1 SAVE_ADAPTER_EVERY_N_ROUNDS=5 SAVE_PROMPTS=1"

output            = /home/gsmithline/Opinion-dynamics-post-training/condor/logs/$(tag).out
error             = /home/gsmithline/Opinion-dynamics-post-training/condor/logs/$(tag).err
log               = /home/gsmithline/Opinion-dynamics-post-training/condor/logs/$(tag).log

notification      = Complete
notify_user       = gabriel.smithline@tue.ellis.eu

max_retries       = 1
on_exit_hold      = (ExitCode =!= 0)

queue tag, style, beta from condor/configs_egta_sftkl.txt
