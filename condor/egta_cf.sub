# HTCondor submit file for the closed-form FJ EGTA sweep.
# Each job runs one beta. Computes q*(v_k|x) = pi_ref * h_p^(1/beta) directly
# (no SGD), drives FJ dynamics, writes trajectory pickles.
#
# These runs join the EGTA cross-eval as --static-run rows (model column =
# base LM at every snapshot since the LM never trains).
#
# Submit:
#   condor_submit_bid 15 condor/egta_cf.sub

universe          = vanilla
executable        = /home/gsmithline/Opinion-dynamics-post-training/condor/run_cf_fj.sh
arguments         = $(tag) $(beta)

request_cpus      = 2
request_memory    = 24G
request_disk      = 30G
request_gpus      = 1
requirements      = (TARGET.CUDAGlobalMemoryMb >= 16000) && (Machine =!= "g054.internal.cluster.is.localnet")

getenv            = False
environment       = "REPO=/home/gsmithline/Opinion-dynamics-post-training CONDA_SH=/home/gsmithline/miniconda3/etc/profile.d/conda.sh ENV_NAME=opdyn WANDB_KEY_FILE=/home/gsmithline/.wandb_key BASE_MODEL=Qwen/Qwen2.5-0.5B-Instruct RETRAIN_T=30 CF_N_BINS=51 OUT_DIR=pokec_dataset/results"

output            = /home/gsmithline/Opinion-dynamics-post-training/condor/logs/$(tag).out
error             = /home/gsmithline/Opinion-dynamics-post-training/condor/logs/$(tag).err
log               = /home/gsmithline/Opinion-dynamics-post-training/condor/logs/$(tag).log

notification      = Complete
notify_user       = gabriel.smithline@tue.ellis.eu

max_retries       = 1
on_exit_hold      = (ExitCode =!= 0)

queue tag, beta from condor/configs_egta_cf.txt
