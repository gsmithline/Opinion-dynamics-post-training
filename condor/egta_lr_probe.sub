# HTCondor submit file for the SFT_LR=5e-4 sanity probe.
#
# Tests whether a 10x larger learning rate on Qwen-2.5-0.5B-Instruct SFT
# breaks the subset-insensitive null we observed at LR=5e-5. Three runs at
# beta=0 (no KL anchor) so the SFT signal dominates:
#   sliver_alc_abs    (train only on abstinent)
#   sliver_alc_nonabs (train only on non-abstinent)
#   track_alc_abs     (train on full V', track abstinent V\S as reference)
#
# Diagnostic: in wandb, compare pred_mean across the three runs. If sliver_alc_abs
# and sliver_alc_nonabs produce visibly different pred_mean, the LM-level null
# at LR=5e-5 was a gradient-magnitude issue. If still identical, the null is
# robust to 10x more aggressive training and we lock it in.
#
# Submit:
#   condor_submit_bid 15 condor/egta_lr_probe.sub

universe          = vanilla
executable        = /home/gsmithline/Opinion-dynamics-post-training/condor/run_one.sh
arguments         = $(tag) $(style) $(beta)

request_cpus      = 2
request_memory    = 32G
request_disk      = 60G
request_gpus      = 1
requirements      = (TARGET.CUDAGlobalMemoryMb >= 16000) && (Machine =!= "g054.internal.cluster.is.localnet")

getenv            = False
environment       = "REPO=/home/gsmithline/Opinion-dynamics-post-training CONDA_SH=/home/gsmithline/miniconda3/etc/profile.d/conda.sh ENV_NAME=opdyn WANDB_KEY_FILE=/home/gsmithline/.wandb_key RETRAIN_T=30 SFT_EPOCHS=1 SFT_LR=5e-4 BASE_MODEL=Qwen/Qwen2.5-0.5B-Instruct USE_LORA=0 USE_CHAT_TEMPLATE=1 SAVE_ADAPTER=1 SAVE_ADAPTER_PER_ROUND=1 SAVE_ADAPTER_EVERY_N_ROUNDS=5 SAVE_PROMPTS=1 SFT_SUBGROUP=$(subgroup) TRACK_SUBGROUP=$(tracker)"

output            = /home/gsmithline/Opinion-dynamics-post-training/condor/logs/$(tag).out
error             = /home/gsmithline/Opinion-dynamics-post-training/condor/logs/$(tag).err
log               = /home/gsmithline/Opinion-dynamics-post-training/condor/logs/$(tag).log

notification      = Complete
notify_user       = gabriel.smithline@tue.ellis.eu

max_retries       = 1
on_exit_hold      = (ExitCode =!= 0)

queue tag, style, beta, subgroup, tracker from condor/configs_egta_lr_probe.txt
